{
  "name": "ai-code-guardian",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered code review, testing, and security analysis tool",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:core": "npm run dev --workspace=packages/core",
    "build:all": "turbo build",
    "test:all": "turbo test",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "db:migrate": "npm run migrate --workspace=packages/supabase"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0"
}
